{
    "application": {
        "name": "CatSprayer",
        "version": "0.1.0",
        "debug": true
    },

    "camera": {
        "width": 1280,
        "height": 720,
        "fps": 30,
        "model": "/usr/share/imx500-models/imx500_network_ssd_mobilenetv2_fpnlite_320x320_pp.rpk",
        "post_process": "/usr/share/rpi-camera-assets/imx500_mobilenet_ssd.json"
    },

    "detection": {
        "target_class": "cat",
        "confidence_threshold": 0.70
    },

    "relay": {
        "gpio_pin": 17,
        "active_high": true,
        "spray_duration": 0.75,
        "cooldown_seconds": 15
    },

    "recording": {
        "enabled": true,
        "pre_event_seconds": 2,
        "post_event_seconds": 5,
        "directory": "data/videos"
    },

    "storage": {
        "log_directory": "data/logs",
        "favorites_directory": "data/favorites",
        "snapshot_directory": "data/snapshots"
    },

    "display": {
        "fullscreen": true,
        "show_boxes": true,
        "show_labels": true,
        "show_confidence": true
    }
}
